NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# MySQL / MariaDB (XAMPP default: user root, empty password, port 3306)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bachat_pragati
DB_USER=root
DB_PASSWORD=

# Production: mysql://user:pass@host:3306/dbname
# DATABASE_URL=mysql://user:pass@host:3306/bachat_pragati

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

SAVINGS_GOAL_AMOUNT=500000

# SHG loans: default monthly % for member requests; vote threshold (0.75 = 75% of eligible voters)
# SHG_DEFAULT_MONTHLY_INTEREST_PERCENT=1.5
# SHG_VOTE_APPROVAL_FRACTION=0.75

CORS_ORIGIN=http://localhost:8081,http://127.0.0.1:8081

LOG_LEVEL=info

# Optional: Google Cloud Translation API key (better limits than default MyMemory fallback)
# GOOGLE_TRANSLATE_API_KEY=
