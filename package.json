    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.2"
